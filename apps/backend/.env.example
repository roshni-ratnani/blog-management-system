# ─────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# MongoDB connection string
# Local development: mongodb://localhost:27017/blogdb
# MongoDB Atlas:     mongodb+srv://<user>:<password>@cluster.mongodb.net/blogdb
MONGODB_URI=mongodb://localhost:27017/blogdb

# Port the Apollo/Express server will listen on
PORT=4000
