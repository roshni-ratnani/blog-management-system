# ─────────────────────────────────────────────
# Frontend Environment Variables (Vite)
# Copy this file to .env and fill in the values
# All variables MUST be prefixed with VITE_ to
# be exposed to the browser by Vite.
# ─────────────────────────────────────────────

# GraphQL API endpoint (your backend server URL)
# Local development: http://localhost:4000/graphql
# Production:        https://your-api-domain.com/graphql
VITE_API_URL=http://localhost:4000/graphql
